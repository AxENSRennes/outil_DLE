{
  "schemaVersion": "v1",
  "templateCode": "CHR-PARFUM-100ML-PILOT",
  "templateName": "Chateau-Renard - Parfum 100mL pilot",
  "description": "Template pilote centré sur un flux réel de dossier de lot avec documents conditionnels et blocages documentaires.",
  "product": {
    "productCode": "CHR-PARF-100ML",
    "productName": "Parfum 100mL",
    "family": "Parfum",
    "formatLabel": "100mL"
  },
  "batchDefaults": {
    "targetBatchSize": 500,
    "batchSizeUnit": "L"
  },
  "contextDimensions": {
    "siteCodes": ["CHR"],
    "lineCodes": ["PMS", "UNI2", "UNI3", "KAWAI"],
    "machineCodes": ["PMS", "UNI2", "UNI3", "KAWAI"],
    "formatFamilies": ["10mL", "30-50mL", "100mL", "200mL"],
    "glitterModes": ["with_glitter", "without_glitter", "any"]
  },
  "stepOrder": [
    "fabrication_bulk",
    "weighing",
    "line_cleaning_previous_run",
    "packaging_execution",
    "finished_product_control",
    "gencod_control_uni2_uni3",
    "intermediate_leakage_pms_glitter",
    "dossier_checklist_pre_qa",
    "pre_qa_review"
  ],
  "steps": {
    "fabrication_bulk": {
      "key": "fabrication_bulk",
      "title": "Dossier de fabrication bulk",
      "kind": "manufacturing",
      "instructions": "Saisir et vérifier les informations bulk, y compris la densité dossier de fabrication.",
      "required": true,
      "repeatPolicy": {
        "mode": "single",
        "minRecords": 1,
        "maxRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": true,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": true,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "manufacturing_order_number",
          "type": "text",
          "label": "Numero OF fabrication",
          "required": true
        },
        {
          "key": "bulk_lot_number",
          "type": "text",
          "label": "Numero de lot bulk",
          "required": true
        },
        {
          "key": "bulk_density",
          "type": "decimal",
          "label": "Densite du jus",
          "required": true
        }
      ]
    },
    "weighing": {
      "key": "weighing",
      "title": "Fichier de pesee",
      "kind": "weighing",
      "instructions": "Renseigner la pesee et calculer les controles issus du fichier client.",
      "required": true,
      "attachmentsPolicy": {
        "supportsAttachments": true,
        "attachmentKinds": ["worksheet"]
      },
      "repeatPolicy": {
        "mode": "single",
        "minRecords": 1,
        "maxRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": true,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": true,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "density_from_bulk_record",
          "type": "decimal",
          "label": "Densite dossier de fabrication",
          "required": true
        },
        {
          "key": "format_code",
          "type": "select",
          "label": "Type de format",
          "required": true,
          "options": [
            { "value": "10mL", "label": "10mL" },
            { "value": "30mL", "label": "30mL" },
            { "value": "50mL_ulli", "label": "50mL Ulli" },
            { "value": "100mL_ulli", "label": "100mL Ulli" },
            { "value": "100mL_quadra", "label": "100mL Quadra" },
            { "value": "100mL_sweet", "label": "100mL Sweet" },
            { "value": "200mL", "label": "200mL" }
          ]
        },
        {
          "key": "gross_measurements",
          "type": "text",
          "label": "Serie de poids bruts du fichier de pesee",
          "required": true
        },
        {
          "key": "tare_measurements",
          "type": "text",
          "label": "Serie de tares du fichier de pesee",
          "required": true
        },
        {
          "key": "target_weight",
          "type": "decimal",
          "label": "Poids cible",
          "unit": "g",
          "required": true
        },
        {
          "key": "average_measured_weight",
          "type": "calculated",
          "label": "Moyenne lot",
          "unit": "g",
          "expressionRef": "average_lot_weight"
        },
        {
          "key": "weight_conformity",
          "type": "calculated",
          "label": "Conformite poids",
          "expressionRef": "weight_conformity"
        }
      ]
    },
    "line_cleaning_previous_run": {
      "key": "line_cleaning_previous_run",
      "title": "Validation nettoyage machine de la production precedente",
      "kind": "preparation",
      "instructions": "Verifier la presence et la conformite du formulaire de nettoyage de la production precedente.",
      "required": true,
      "repeatPolicy": {
        "mode": "single",
        "minRecords": 1,
        "maxRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": false,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": false,
        "meaning": "performed_by"
      },
      "attachmentsPolicy": {
        "supportsAttachments": true,
        "attachmentKinds": ["checklist", "worksheet"]
      },
      "fields": [
        {
          "key": "cleaning_form_present",
          "type": "select",
          "label": "Formulaire present",
          "required": true,
          "options": [
            { "value": "yes", "label": "Oui" },
            { "value": "no", "label": "Non" }
          ]
        }
      ]
    },
    "packaging_execution": {
      "key": "packaging_execution",
      "title": "Execution conditionnement",
      "kind": "packaging",
      "instructions": "Renseigner l'execution sur ligne sans imposer de gate de revue entre les etapes courantes.",
      "required": true,
      "repeatPolicy": {
        "mode": "per_team",
        "minRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": true,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": true,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "line_code",
          "type": "select",
          "label": "Ligne de conditionnement",
          "required": true,
          "options": [
            { "value": "PMS", "label": "PMS" },
            { "value": "UNI2", "label": "UNI2" },
            { "value": "UNI3", "label": "UNI3" },
            { "value": "KAWAI", "label": "KAWAI" }
          ]
        },
        {
          "key": "team_identifier",
          "type": "text",
          "label": "Equipe",
          "required": true
        }
      ]
    },
    "finished_product_control": {
      "key": "finished_product_control",
      "title": "Controle produit fini sur ligne",
      "kind": "finished_product_control",
      "instructions": "Tracer les controles intermediaires et boites de controle repetes.",
      "required": true,
      "repeatPolicy": {
        "mode": "per_box",
        "minRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": true,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": true,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "box_number",
          "type": "number",
          "label": "Numero de box",
          "required": true
        },
        {
          "key": "defect_count",
          "type": "number",
          "label": "Nombre de defauts",
          "required": true
        },
        {
          "key": "decision",
          "type": "select",
          "label": "Decision box",
          "required": true,
          "options": [
            { "value": "accepted", "label": "Acceptee" },
            { "value": "rejected", "label": "Refusee" }
          ]
        }
      ]
    },
    "gencod_control_uni2_uni3": {
      "key": "gencod_control_uni2_uni3",
      "title": "Controle gencod UNI2 / UNI3",
      "kind": "in_process_control",
      "instructions": "Controler le gencod en debut, milieu et fin de production pour UNI2 et UNI3.",
      "required": true,
      "applicability": {
        "machineCodes": ["UNI2", "UNI3"],
        "whenNotApplicable": "mark_na"
      },
      "repeatPolicy": {
        "mode": "per_event",
        "minRecords": 3,
        "maxRecords": 3
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": false,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": false,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "control_moment",
          "type": "select",
          "label": "Moment de controle",
          "required": true,
          "options": [
            { "value": "start", "label": "Debut" },
            { "value": "middle", "label": "Milieu" },
            { "value": "end", "label": "Fin" }
          ]
        },
        {
          "key": "gencod_conformity",
          "type": "select",
          "label": "Conformite gencod",
          "required": true,
          "options": [
            { "value": "conform", "label": "Conforme" },
            { "value": "non_conform", "label": "Non conforme" }
          ]
        }
      ]
    },
    "intermediate_leakage_pms_glitter": {
      "key": "intermediate_leakage_pms_glitter",
      "title": "Controle intermediaire etancheite + paillettes PMS",
      "kind": "in_process_control",
      "instructions": "Controle applicable uniquement pour PMS avec paillettes.",
      "required": true,
      "applicability": {
        "machineCodes": ["PMS"],
        "glitterMode": "with_glitter",
        "whenNotApplicable": "mark_na"
      },
      "repeatPolicy": {
        "mode": "per_box",
        "minRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": false,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": false,
        "meaning": "performed_by"
      },
      "fields": [
        {
          "key": "box_number",
          "type": "number",
          "label": "Numero de box",
          "required": true
        },
        {
          "key": "leakage_conformity",
          "type": "select",
          "label": "Conformite etancheite",
          "required": true,
          "options": [
            { "value": "conform", "label": "Conforme" },
            { "value": "non_conform", "label": "Non conforme" }
          ]
        },
        {
          "key": "glitter_presence",
          "type": "select",
          "label": "Presence paillettes",
          "required": true,
          "options": [
            { "value": "yes", "label": "Oui" },
            { "value": "no", "label": "Non" }
          ]
        }
      ]
    },
    "dossier_checklist_pre_qa": {
      "key": "dossier_checklist_pre_qa",
      "title": "Check-list documents du dossier de lot",
      "kind": "review",
      "instructions": "Comparer les documents attendus au contexte reel du lot avant passage en revue.",
      "required": true,
      "repeatPolicy": {
        "mode": "single",
        "minRecords": 1,
        "maxRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": false,
        "blocksSignature": false,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": false,
        "meaning": "reviewed_by"
      },
      "fields": [
        {
          "key": "expected_documents_complete",
          "type": "select",
          "label": "Documents attendus presents",
          "required": true,
          "options": [
            { "value": "yes", "label": "Oui" },
            { "value": "no", "label": "Non" }
          ]
        }
      ]
    },
    "pre_qa_review": {
      "key": "pre_qa_review",
      "title": "Revue avant passage qualite",
      "kind": "pre_qa_review",
      "instructions": "Bloquer la transmission qualite si le dossier applicable n'est pas complet.",
      "required": true,
      "repeatPolicy": {
        "mode": "single",
        "minRecords": 1,
        "maxRecords": 1
      },
      "blockingPolicy": {
        "blocksExecutionProgress": false,
        "blocksStepCompletion": true,
        "blocksSignature": true,
        "blocksPreQaHandoff": true
      },
      "signaturePolicy": {
        "required": true,
        "meaning": "reviewed_by"
      },
      "fields": [
        {
          "key": "dossier_complete",
          "type": "select",
          "label": "Dossier complet",
          "required": true,
          "options": [
            { "value": "yes", "label": "Oui" },
            { "value": "no", "label": "Non" }
          ]
        },
        {
          "key": "review_comment",
          "type": "text",
          "label": "Commentaire de revue"
        }
      ]
    }
  },
  "calculations": [
    {
      "key": "average_lot_weight",
      "label": "Moyenne lot",
      "backendRef": "client_chateau_renard.weighing.average_lot_weight_from_measurement_series",
      "inputs": ["gross_measurements", "tare_measurements", "format_code"],
      "outputFieldKey": "average_measured_weight"
    },
    {
      "key": "weight_conformity",
      "label": "Conformite poids",
      "backendRef": "client_chateau_renard.weighing.weight_conformity",
      "inputs": ["density_from_bulk_record", "format_code", "target_weight", "average_measured_weight"],
      "outputFieldKey": "weight_conformity"
    }
  ],
  "releaseRules": {
    "requiresAllRequiredStepsSigned": true,
    "requiresPreQaReview": true,
    "blocksOnOpenExceptions": true
  }
}
