{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dle-saas.local/schemas/mmr-version.schema.json",
  "title": "MMR Version Schema",
  "description": "Minimal schema for a versioned master manufacturing record used to instantiate electronic batch records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "templateCode",
    "templateName",
    "product",
    "stepOrder",
    "steps"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "templateCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "templateName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productCode",
        "productName",
        "family",
        "formatLabel"
      ],
      "properties": {
        "productCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "productName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "family": {
          "type": "string",
          "maxLength": 255
        },
        "formatLabel": {
          "type": "string",
          "maxLength": 255
        }
      }
    },
    "batchDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targetBatchSize": {
          "type": "number"
        },
        "batchSizeUnit": {
          "type": "string",
          "maxLength": 50
        }
      }
    },
    "stepOrder": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "uniqueItems": true
    },
    "steps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/step"
      }
    },
    "calculations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/calculation"
      }
    },
    "releaseRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiresAllRequiredStepsSigned": {
          "type": "boolean"
        },
        "requiresPreQaReview": {
          "type": "boolean"
        },
        "blocksOnOpenExceptions": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "kind",
        "fields",
        "signaturePolicy"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "kind": {
          "type": "string",
          "enum": [
            "preparation",
            "material_confirmation",
            "weighing",
            "manufacturing",
            "pre_qa_review",
            "in_process_control",
            "bulk_handover",
            "packaging",
            "finished_product_control",
            "review"
          ]
        },
        "instructions": {
          "type": "string",
          "maxLength": 10000
        },
        "attachmentsPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supportsAttachments": {
              "type": "boolean"
            },
            "attachmentKinds": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "checklist",
                  "worksheet",
                  "label_scan",
                  "photo",
                  "other"
                ]
              }
            }
          }
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "signaturePolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "meaning"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "meaning": {
              "type": "string",
              "enum": [
                "performed_by",
                "reviewed_by",
                "approved_by",
                "released_by"
              ]
            }
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "type",
        "label"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "number",
            "decimal",
            "boolean",
            "datetime",
            "select",
            "material_lot_ref",
            "equipment_ref",
            "checklist_ref",
            "label_ref",
            "calculated"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "unit": {
          "type": "string",
          "maxLength": 50
        },
        "required": {
          "type": "boolean"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "value",
              "label"
            ],
            "properties": {
              "value": {
                "type": "string",
                "maxLength": 100
              },
              "label": {
                "type": "string",
                "maxLength": 255
              }
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            },
            "pattern": {
              "type": "string"
            }
          }
        },
        "expressionRef": {
          "type": "string",
          "maxLength": 100
        },
        "visibleIf": {
          "type": "string",
          "maxLength": 255
        },
        "requiredIf": {
          "type": "string",
          "maxLength": 255
        },
        "optionalInV1": {
          "type": "boolean"
        }
      }
    },
    "calculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "backendRef"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "backendRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 100
          }
        },
        "outputFieldKey": {
          "type": "string",
          "maxLength": 100
        }
      }
    }
  }
}
